; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Orchestrator GDExtension Tests"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[orchestrator]

ui/components_panel/show_graph_friendly_names=false
ui/components_panel/show_function_friendly_names=false
ui/graph/grid_pattern="Dots"
ui/graph/show_advanced_tooltips=true
ui/nodes/resize_to_content=true
